{
  "lexicon": 1,
  "id": "io.github.uwx.yjs.mls.room",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "properties": {
          "createdAt": {
            "type": "string",
            "format": "datetime",
            "description": "When this room was created"
          },
          "creator": {
            "type": "string",
            "format": "did",
            "description": "The DID of the room creator, who is responsible for issuing MLS commits"
          },
          "authorizedDids": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "did"
            },
            "description": "If set, an allowlist of DIDs that are allowed to participate in this room"
          },
          "cipherSuite": {
            "type": "string",
            "description": "The MLS ciphersuite identifier used by this group"
          },
          "groupInfo": {
            "type": "bytes",
            "description": "The serialized MLS GroupInfo with external pub and ratchet tree extensions, for external joins"
          }
        },
        "required": [
          "createdAt",
          "creator",
          "cipherSuite"
        ]
      },
      "description": "An MLS-encrypted Y.js room declaration"
    }
  }
}
