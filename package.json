{
    "name": "y-atproto",
    "type": "module",
    "license": "MIT",
    "version": "1.0.0",
    "main": "out/index.js",
    "scripts": {
        "build:typelex": "typelex compile io.github.uwx.yjs.*",
        "build:lex": "lex-cli generate",
        "build:demos": "pnpm -r build",
        "build": "pnpm build:typelex && pnpm build:lex && tsc && pnpm build:demos",
        "deploy:demo-excalidraw": "wispctl deploy maxine.puppykitty.racing -p demos/excalidraw/dist -s y-atproto-demo-excalidraw --store \".wisp-store\"",
        "deploy:demo-monaco": "wispctl deploy maxine.puppykitty.racing -p demos/monaco-react/dist -s y-atproto-demo-monaco --store \".wisp-store\"",
        "deploy:demo-prosemirror": "wispctl deploy maxine.puppykitty.racing -p demos/react-prosemirror/dist -s y-atproto-demo-prosemirror --store \".wisp-store\"",
        "deploy:demos": "pnpm build:demos && pnpm deploy:demo-excalidraw && pnpm deploy:demo-monaco && pnpm deploy:demo-prosemirror"
    },
    "devDependencies": {
        "@atcute/lex-cli": "^2.5.3",
        "@biomejs/biome": "1.9.4",
        "@typelex/cli": "^0.4.0",
        "@typelex/emitter": "^0.4.0"
    },
    "dependencies": {
        "@atcute/atproto": "^3.1.10",
        "@atcute/client": "^4.2.1",
        "@atcute/jetstream": "^1.1.2",
        "@atcute/lexicons": "^1.2.9",
        "@atcute/tid": "^1.1.2",
        "@atcute/uint8array": "^1.1.1",
        "js-base64": "^3.7.8",
        "kitty-agent": "13.0.1",
        "lib0": "^0.2.117",
        "y-atproto": "^1.0.0",
        "y-protocols": "^1.0.7",
        "yjs": "^13.6.29"
    },
    "packageManager": "pnpm@10.32.0+sha512.9b2634bb3fed5601c33633f2d92593f506270a3963b8c51d2b2d6a828da615ce4e9deebef9614ccebbc13ac8d3c0f9c9ccceb583c69c8578436fa477dbb20d70"
}
